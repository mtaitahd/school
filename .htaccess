RewriteEngine On

# Announcement detail: /announcement/some-slug -> announcement.php?slug=some-slug
RewriteRule ^announcement/([a-zA-Z0-9_-]+)/?$ announcement.php?slug=$1 [L,QSA]

# Notes detail: /notes/some-slug -> notes.php?slug=some-slug
RewriteRule ^notes/([a-zA-Z0-9_-]+)/?$ notes.php?slug=$1 [L,QSA]

# Redirect .php URLs to clean URLs
RewriteCond %{THE_REQUEST} \s/([^.]+)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# Internally rewrite clean URLs to .php files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]
