# =====================================================
# KONA YA HISABATI - Environment Configuration
# Copy this file to .env and fill in your values
# =====================================================

# SMS API Configuration
# SMS_API_TOKEN=your_webline_token_here
# SMS_SENDER_ID=TAARIFA
# SMS_BASE_URL=https://sms.webline.africa/api/v3/sms/send

# Database Configuration (optional - override defaults)
# DB_HOST=localhost
# DB_NAME=kona_hisabati
# DB_USER=root
# DB_PASS=

# Application Settings
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://yourdomain.com

# Payment Settings - Snippe API (2026-01-25)
# Get your API key from https://api.snippe.sh
# SNIPPE_API_KEY=sk_live_xxxxxxxxxxxxxx
# SNIPPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxx

# Security Settings
# SESSION_LIFETIME=7200
